diff --git a/app/src/settings_view/custom_inference_modal.rs b/app/src/settings_view/custom_inference_modal.rs
index ecd00d1..8ab27a6 100644
--- a/app/src/settings_view/custom_inference_modal.rs
+++ b/app/src/settings_view/custom_inference_modal.rs
@@ -895,13 +895,23 @@ fn validate_url(url: &str) -> Result<(), &'static str> {
         return Ok(());
     }
     let parsed = Url::parse(url).map_err(|_| "Invalid URL")?;
-    if parsed.scheme() != "https" {
+    // Loopback hosts (e.g. `localhost`, `127.0.0.1`, `[::1]`) are allowed to use
+    // `http` so users can point Warp at locally-running OpenAI-compatible
+    // servers such as Ollama behind a LiteLLM proxy. Non-loopback hosts still
+    // require `https`, and private / link-local / unspecified addresses are
+    // still rejected regardless of scheme.
+    let scheme_ok = match parsed.scheme() {
+        "https" => true,
+        "http" => parsed.host_str().is_some_and(is_loopback_host),
+        _ => false,
+    };
+    if !scheme_ok {
         return Err("URL must use HTTPS");
     }
     let Some(host) = parsed.host_str().filter(|h| !h.is_empty()) else {
         return Err("URL must include a host");
     };
-    if is_restricted_host(host) {
+    if is_restricted_host(host) && !is_loopback_host(host) {
         return Err("URL must not use a local or private host");
     }
     Ok(())
@@ -915,7 +925,7 @@ fn is_endpoint_form_valid(name: &str, url: &str, api_key: &str, has_models: bool
         && validate_url(url).is_ok()
 }
 
-fn is_restricted_host(host: &str) -> bool {
+fn is_loopback_host(host: &str) -> bool {
     let host = host
         .strip_prefix('[')
         .and_then(|host| host.strip_suffix(']'))
@@ -923,6 +933,18 @@ fn is_restricted_host(host: &str) -> bool {
     if host.eq_ignore_ascii_case("localhost") {
         return true;
     }
+    match host.parse::<IpAddr>() {
+        Ok(IpAddr::V4(ip)) => ip.is_loopback(),
+        Ok(IpAddr::V6(ip)) => ip.is_loopback(),
+        Err(_) => false,
+    }
+}
+
+fn is_restricted_host(host: &str) -> bool {
+    let host = host
+        .strip_prefix('[')
+        .and_then(|host| host.strip_suffix(']'))
+        .unwrap_or(host);
     host.parse::<IpAddr>().is_ok_and(is_restricted_ip)
 }
 
